{
  "expo": {
    "name": "Harmony",
    "slug": "Harmony",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/harmony-icon.jpeg",
    "scheme": "harmony",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.shakirsadiq.Harmony"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/harmony-icon.jpeg",
          "imageResizeMode": "contain",
          "android": {
            "image": "./assets/images/harmony-icon.jpeg",
            "imageWidth": 120
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "409a6b2a-b251-4689-b821-05fe46a993a6"
      }
    },
    "owner": "shakirsadiq",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/409a6b2a-b251-4689-b821-05fe46a993a6"
    }
  }
}
